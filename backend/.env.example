# 激活的LLM模型（从以下选一个填入LLM_PROVIDER）
# 可选: kimi | glm-5 | glm-4.7 | glm-4.7-flash | minimax-m2.5 | minimax-m2.7
LLM_PROVIDER=glm-4.7-flash

# Kimi API (月之暗面)
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# GLM API (智谱AI)
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# MiniMax API
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# AIping TTS
AIPING_API_KEY=your_aiping_api_key_here
AIPING_TTS_URL=https://aiping.cn/api/v1/audio/speech
AIPING_VOICE_ID=female-shaonv
AIPING_TTS_MODEL=MiniMax-Speech-2.8-hd

# 服务端口
PORT=3001

# CORS 允许的前端地址
FRONTEND_URL=http://localhost:3000
