# ── LLM路由配置 ────────────────────────────────────────────────
# 聊天阶段首选模型 (Kimi-K2.5 via AIping)
CHAT_LLM_MODEL=kimi-k2-5

# 报告生成首选模型
ANALYZE_LLM_MODEL=glm-4.7
ANALYZE_LLM_FALLBACK=kimi-k2-5

# 默认全局模型（未指定时的fallback）
LLM_PROVIDER=glm-4.7-flash

# ── Kimi-K2.5 via AIping ────────────────────────────────────────
KIMI_K2_API_KEY=your_aiping_kimi_k2_api_key_here
KIMI_K2_BASE_URL=https://aiping.cn/api/v1
KIMI_K2_MODEL=kimi-k2.5

# ── Kimi 原生 API (月之暗面) ────────────────────────────────────
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ── GLM API (智谱AI) ────────────────────────────────────────────
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── MiniMax API ─────────────────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ── AIping TTS ──────────────────────────────────────────────────
AIPING_API_KEY=your_aiping_api_key_here
AIPING_TTS_URL=https://aiping.cn/api/v1/audio/speech
AIPING_VOICE_ID=female-shaonv
AIPING_TTS_MODEL=MiniMax-Speech-2.8-hd

# ── 服务器 ──────────────────────────────────────────────────────
PORT=5175
FRONTEND_URL=http://localhost:3004
